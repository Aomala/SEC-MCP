{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "mkdir -p public/static && cp -R src/sec_mcp/static/. public/static/ && cp src/sec_mcp/static/index.html public/index.html && cp src/sec_mcp/static/docs.html public/docs.html && cp src/sec_mcp/static/explorer.html public/explorer.html",
  "outputDirectory": "public",
  "installCommand": "echo 'skip install'",
  "rewrites": [
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/explorer", "destination": "/explorer.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
